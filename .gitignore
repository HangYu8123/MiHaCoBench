# Python bytecode and pytest caches from running the graders
__pycache__/
*.py[cod]
.pytest_cache/

# Transient runner output
results.json
experiment_mihaco/results/

# Ignore the .github/ working tree EXCEPT the CI workflows, which must be tracked
# so GitHub Actions runs them. (The HarnessFlow pack under .github/HarnessFlow/ stays
# untracked by this rule — drop the `.github/*` line if you want to version it too.)
.github/*
!.github/workflows/